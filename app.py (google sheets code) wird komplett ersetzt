import streamlit as st
import pandas as pd
import gspread
from oauth2client.service_account import ServiceAccountCredentials
import time

# -------- GOOGLE SHEETS VERBINDUNG --------

scope = [
    "https://spreadsheets.google.com/feeds",
    "https://www.googleapis.com/auth/drive"
]

creds = ServiceAccountCredentials.from_json_keyfile_name(
    r"C:\Users\HP\Documents\esp32_dashboard\esp32-v2-dahboard-9f74cdd5d2c3.json",
    scope
)

client = gspread.authorize(creds)

sheet = client.open_by_url(
    "https://docs.google.com/spreadsheets/d/16qSRsdqKqTuPO_ETw0Ee0vPv7hJxNWvxadl4e8w75mQ/edit?gid=0#gid=0"
).sheet1

# -------- STREAMLIT DASHBOARD --------

st.set_page_config(page_title="ESP32 Dashboard", layout="wide")

st.title("📡 ESP32 Live Dashboard")

placeholder = st.empty()

while True:

    data = sheet.get_all_records()

    df = pd.DataFrame(data)

    with placeholder.container():

        st.subheader("📋 Live Daten")

        st.dataframe(df)

        if not df.empty:

            if "Gewicht" in df.columns:

                st.subheader("⚖️ Gewicht Verlauf")

                st.line_chart(df["Gewicht"])

            if "MX" in df.columns:

                st.subheader("🧲 Magnetfeld X")

                st.line_chart(df["MX"])

    time.sleep(2)
    
