#include <Wire.h>
#include <SparkFun_Qwiic_Scale_NAU7802_Arduino_Library.h>
#include <SparkFun_TMAG5273_Arduino_Library.h>

// -------- Sensor-Objekte --------
NAU7802 scale;
TMAG5273 mag;

// -------- Pins --------
#define TEMP_PIN 34   // KF1248 analog Temperatur

void setup() {
  Serial.begin(115200);
  delay(1000);

  Wire.begin();

  Serial.println("Start Sensor Setup...");

  // -------- ADC FIX (WICHTIG für ESP32) --------
  analogReadResolution(12);                 // 0–4095
  analogSetPinAttenuation(TEMP_PIN, ADC_11db);

  // -------- Gewichtssensor --------
  if (!scale.begin()) {
    Serial.println("ERROR: Scale nicht gefunden!");
  } else {
    Serial.println("Scale OK");
  }

  // -------- Magnetfeldsensor --------
  if (mag.begin() != 0) {
    Serial.println("ERROR: Magnet Sensor nicht gefunden!");
  } else {
    Serial.println("Magnet OK");
  }

  Serial.println("Setup fertig");
}

void loop() {

  // -------- Gewicht --------
  long gewicht = 0;
  if (scale.available()) {
    gewicht = scale.getReading();
  }

  // -------- Magnetfeld --------
  float mx = mag.getXData();
  float my = mag.getYData();
  float mz = mag.getZData();

  // -------- Temperatur (analog KF1248) --------
  int rawTemp = analogRead(TEMP_PIN);

  // -------- CSV OUTPUT --------
  Serial.print(gewicht);
  Serial.print(",");
  Serial.print(mx);
  Serial.print(",");
  Serial.print(my);
  Serial.print(",");
  Serial.print(mz);
  Serial.print(",");
  Serial.println(rawTemp);

  delay(18000);

}
