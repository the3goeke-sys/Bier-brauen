import streamlit as st
import pandas as pd
import sqlite3

st.set_page_config(page_title="ESP32 Dashboard", layout="wide")

st.title("🍺 Digitaler Zwilling Brauanlage")

conn = sqlite3.connect("brauerei.db")

df = pd.read_sql_query("""
SELECT *
FROM messungen
ORDER BY id DESC
LIMIT 500
""", conn)

if df.empty:
    st.warning("Noch keine Daten vorhanden.")
else:

    df = df.sort_values("id")

    col1, col2 = st.columns(2)

    with col1:
        st.metric(
            "Aktuelles Gewicht",
            round(float(df["gewicht"].iloc[-1]), 2)
        )

    with col2:
        st.metric(
            "Temperatur Rohwert",
            int(float(df["temperatur"].iloc[-1]))
        )

    st.subheader("⚖️ Gewicht")

    st.line_chart(df["gewicht"])

    st.subheader("🌡️ Temperatur")

    st.line_chart(df["temperatur"])

    st.subheader("📋 Letzte Messungen")

    st.dataframe(df.tail(100))
    
