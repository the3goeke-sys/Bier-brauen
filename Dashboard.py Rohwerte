print("System gestartet...")

while True:
    try:
        line = ser.readline().decode('utf-8').strip()

        if not line:
            continue

        print("Empfangen:", line)

        data = line.split(",")

        if len(data) != 4:
            print("Ungültige Daten:", line)
            continue

        sheet.append_row([
            time.strftime("%H:%M:%S"),
            data[0],
            data[1],
            data[2],
            data[3]
        ])

        print("OK:", data)

    except Exception as e:
        print("Fehler:", e)

